    {
      "pass": "unbounded-collection",
      "file": "src/analysis/passes/sink-filter-pass.ts",
      "reason": "chars array in parseNumber is bounded by input string length"
    }
  ],

  "severity": "low",
  "categories": ["security", "reliability", "performance", "architecture"]
}
