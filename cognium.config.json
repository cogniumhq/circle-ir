    },
    {
      "pass": "redundant-loop-computation",
      "file": "src/analysis/metrics/passes/cohesion-metrics-pass.ts",
      "line": 38,
      "reason": "type.methods.length changes each iteration over types - not loop-invariant"
    },
    {
      "pass": "redundant-loop-computation",
      "file": "src/analysis/metrics/passes/cohesion-metrics-pass.ts",
